{
  "compilerOptions": {
    // File Layout
    "rootDir": "Project Files",
    "outDir": "Project Files",

    // Environment Settings
    "module": "esnext",
    "target": "esnext",
    "lib": ["esnext", "dom", "dom.iterable"],
    "types": [],

    // Other Outputs
    "sourceMap": true,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,

    // Output Safety
    "noEmitOnError": true,

    // Recommended Options
    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "auto",
    "skipLibCheck": true,

    // Don't emit declarations (this is an app, not a library)
    "declaration": false,
    "declarationMap": false
  },
  "files": ["Project Files/script.ts"]
}
